{
  "name": "live-mcp-for-obsidian",
  "version": "0.1.0",
  "description": "A live connection between AI assistants and your running Obsidian instance. Full app automation — not just file access.",
  "type": "module",
  "bin": {
    "live-mcp-for-obsidian": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/cli.js",
