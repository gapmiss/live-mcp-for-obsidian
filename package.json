    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yargs": "^17.7.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "model-context-protocol",
    "automation",
    "claude",
    "ai",
    "devtools",
    "plugins"
  ],
  "author": "gapmiss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gapmiss/live-mcp-for-obsidian.git"
  },
  "homepage": "https://github.com/gapmiss/live-mcp-for-obsidian#readme",
